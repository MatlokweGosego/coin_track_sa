<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- LOTTIE BACKGROUND ANIMATION -->
    <com.airbnb.lottie.LottieAnimationView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_rawRes="@raw/background_animation"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:scaleType="centerCrop" />

    <!-- SEMI-TRANSPARENT OVERLAY FOR BETTER CONTENT READABILITY -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <!-- YOUR ORIGINAL DIALOG CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_gravity="center">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add New Category"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCategoryName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Category Name"
            app:boxStrokeColor="#6C63FF"
            app:hintTextColor="#6C63FF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCategoryName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="#1A1A2E" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBudget"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Budget Amount"
            app:boxStrokeColor="#6C63FF"
            app:hintTextColor="#6C63FF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBudget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="#1A1A2E" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Choose Category Color"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/colorContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Unique Color Palette -->
                <TextView
                    android:id="@+id/colorCoral"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="#FF6B6B"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:backgroundTint="#FF6B6B" />

                <TextView
                    android:id="@+id/colorTeal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="#4ECDC4"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/colorSunset"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="#FFE66D"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/colorLavender"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="#A8E6CF"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/colorBerry"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="#FF8C94"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/colorMint"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="#B5EAD7"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/colorPeach"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="#FFD3B6"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/colorBlueGray"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="#667EEA"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#E2E8F0"
                android:text="Cancel"
                android:textColor="#64748B"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#6C63FF"
                android:text="Save Category"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>