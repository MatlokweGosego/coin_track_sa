<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Period Selector -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Period"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50" />

                <Spinner
                    android:id="@+id/spinnerPeriod"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/spinner_background" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Period Range -->
        <TextView
            android:id="@+id/tvPeriodRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date Range"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#4CAF50">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Financial Summary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tvTotalIncome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Income: R0.00"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvTotalExpenses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expenses: R0.00"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tvNetSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Net Savings: R0.00"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Category Chart -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📈 Spending by Category"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginBottom="12dp" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/chartExpenses"
                    android:layout_width="match_parent"
                    android:layout_height="250dp" />

                <TextView
                    android:id="@+id/tvChartEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No expense data for this period"
                    android:textColor="#7F8C8D"
                    android:visibility="gone"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:padding="32dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Savings Rate Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Savings Rate"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50" />

                <TextView
                    android:id="@+id/tvSavingsRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Savings Rate: 0%"
                    android:layout_marginTop="8dp" />

                <ProgressBar
                    android:id="@+id/progressSavings"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Budget Usage Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Budget Performance"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50" />

                <TextView
                    android:id="@+id/tvBudgetUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Budget Usage: 0%"
                    android:layout_marginTop="8dp" />

                <ProgressBar
                    android:id="@+id/progressBudgetUsage"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Goal Performance Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Goal Performance"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50" />

                <TextView
                    android:id="@+id/tvMinGoalPerformance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Goals: 0/0"
                    android:layout_marginTop="8dp" />

                <ProgressBar
                    android:id="@+id/progressMinGoals"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tvMaxGoalPerformance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maximum Goals: 0/0"
                    android:layout_marginTop="12dp" />

                <ProgressBar
                    android:id="@+id/progressMaxGoals"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tvGoalPerformanceMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Performance message"
                    android:layout_marginTop="12dp"
                    android:padding="8dp"
                    android:background="#33000000"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>